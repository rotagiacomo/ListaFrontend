<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="550.0" prefWidth="755.0" spacing="20.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.listafrontend.ListaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <TextArea fx:id="zonaPerStampaLista" prefHeight="200.0" prefWidth="200.0" />
   <ChoiceBox fx:id="sceltaTecnica" prefWidth="150.0" />
   <Button mnemonicParsing="false" onAction="#addElement" text="Aggiungi a lista" />
   <Button mnemonicParsing="false" onAction="#removeElement" text="Rimuovi da lista" />
</VBox>
